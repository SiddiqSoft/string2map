                    ]
                }
            }
        },
        {
            "name": "Windows-x64-Debug",
            "displayName": "Win x64 Debug",
            "description": "Target Win with Ninja and MSVC (Debug) - Auto-detects Visual Studio version",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "toolset": {
                "value": "host=x64",
