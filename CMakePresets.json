{
    "version": 8,
    "include": [
        "project-base.json"
    ],
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 29
    },
    "configurePresets": [
        {
            "name": "Common-Base",
            "hidden": true,
            "inherits": "Project-Base",
            "generator": "Ninja",
            "environment": {
                "CTEST_PARALLEL_LEVEL": "0",
                "CMAKE_COLOR_DIAGNOSTICS": "1"
            },
            "cacheVariables": {
                "CPM_SOURCE_CACHE": "${sourceParentDir}/.cpmcache"
            }
        },
        {
            "name": "Apple-LLVM-Debug",
            "displayName": "Apple-LLVM-Debug (Homebrew LLVM)",
            "description": "Using compilers: C = /opt/homebrew/opt/llvm/bin/clang, CXX = /opt/homebrew/opt/llvm/bin/clang++",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": "Common-Base",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/${presetName}",
                "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm/bin/clang",
                "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++",
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_OSX_SYSROOT": "/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "Apple-LLVM-Release",
            "displayName": "Apple-LLVM-Release (Homebrew LLVM)",
            "description": "Using compilers: C = /opt/homebrew/opt/llvm/bin/clang, CXX = /opt/homebrew/opt/llvm/bin/clang++",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": "Common-Base",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/${presetName}",
                "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm/bin/clang",
                "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++",
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_OSX_SYSROOT": "/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "Apple-Debug",
            "displayName": "Apple-Debug (Default Xcode)",
            "description": "Using default Apple compiler toolchain from Xcode",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": "Common-Base",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/${presetName}",
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "Apple-Release",
            "displayName": "Apple-Release (Default Xcode)",
            "description": "Using default Apple compiler toolchain from Xcode",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": "Common-Base",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/${presetName}",
                "CMAKE_BUILD_TYPE": "Release"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "Darwin-LLVM",
            "inherits": "Apple-LLVM-Release"
        },
        {
            "name": "Darwin",
            "inherits": "Apple-Release"
        },
        {
            "name": "Linux-Clang-Debug",
            "displayName": "Linux Clang Debug",
            "description": "Target Linux Clang (Debug)",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "installDir": "${sourceDir}/install/${presetName}",
            "inherits": "Common-Base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "/usr/bin/clang",
                "CMAKE_CXX_COMPILER": "/usr/bin/clang++"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "vendor": {
                "microsoft.com/VisualStudioRemoteSettings/CMake/2.0": {
                    "remoteSourceRootDir": "$env{HOME}/.vs/$ms{projectDirName}"
                }
            }
        },
